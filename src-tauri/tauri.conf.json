{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "com.merlino.desktop",
  "productName": "Merlino",
  "version": "0.1.0",
  "build": {
    "frontendDist": "../public"
  },
  "app": {
    "windows": [],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
